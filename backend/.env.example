# ─────────────────────────────────────────────
# Meta Ads Audit — Backend Environment Template
# Copy to .env and fill in real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# ── Runtime ──────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Security (REQUIRED) ───────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-hex-chars

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meta_ads_audit

# ── Redis / Celery ───────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS & Frontend ──────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=https://your-domain.com
FRONTEND_APP_URL=https://your-domain.com

# ── Meta Ads API ─────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://your-domain.com/dashboard/meta/callback
META_API_VERSION=v19.0
META_OAUTH_SCOPES=ads_read,ads_management,business_management
META_STATE_TTL_MINUTES=10
META_INITIAL_SYNC_LOOKBACK_DAYS=90
META_INCREMENTAL_SYNC_LOOKBACK_DAYS=30
META_HTTP_TIMEOUT_SECONDS=60
META_PAGINATION_MAX_PAGES=250

# ── AI Provider ──────────────────────────────
# Supported values: gemini | openai | anthropic | mock
AI_PROVIDER=gemini
AI_API_KEY=your_ai_api_key
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2

# ── Email / SMTP ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM=noreply@your-domain.com
SMTP_STARTTLS=true

# ── Sentry (optional) ────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Rate limits (optional — defaults shown) ──
RATE_LIMIT_AUTH_REQUESTS=6
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_UPLOAD_REQUESTS=6
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=3600
RATE_LIMIT_AUDIT_REQUESTS=10
RATE_LIMIT_AUDIT_WINDOW_SECONDS=3600

# ── Free plan caps (optional — defaults shown) ─
FREE_MAX_AD_ACCOUNTS=1
FREE_MAX_FINDINGS=3
FREE_MAX_RECOMMENDATIONS=2
FREE_MAX_HISTORY_ITEMS=4
FREE_MAX_TREND_POINTS=6
FREE_MAX_REPORTS_PER_MONTH=3
