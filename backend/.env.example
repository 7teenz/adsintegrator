# ------------------------------
# Required (local)
# ------------------------------
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/meta_ads_audit
REDIS_URL=redis://redis:6379/0
SECRET_KEY=<generate: python -c "import secrets; print(secrets.token_hex(32))">
ENCRYPTION_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
DEBUG=false

# ------------------------------
# API behavior
# ------------------------------
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
FRONTEND_APP_URL=http://localhost:3000

# ------------------------------
# Meta OAuth / API
# Use META_APP_ID=mock for local development without real credentials
# ------------------------------
META_APP_ID=mock
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/dashboard/meta/callback
META_API_VERSION=v19.0
META_OAUTH_SCOPES=ads_read,ads_management,business_management
META_STATE_TTL_MINUTES=10
META_INITIAL_SYNC_LOOKBACK_DAYS=90
META_INCREMENTAL_SYNC_LOOKBACK_DAYS=30
META_HTTP_TIMEOUT_SECONDS=60
META_PAGINATION_MAX_PAGES=250

# ------------------------------
# AI explanation layer (optional)
# ------------------------------
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2
AI_PROMPT_VERSION=v1

# ------------------------------
# Email delivery
# ------------------------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_STARTTLS=false

# ------------------------------
# Optional local observability
# ------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0

# ------------------------------
# Local throttling defaults
# ------------------------------
RATE_LIMIT_AUTH_REQUESTS=6
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_UPLOAD_REQUESTS=6
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=3600
RATE_LIMIT_AUDIT_REQUESTS=10
RATE_LIMIT_AUDIT_WINDOW_SECONDS=3600

# ------------------------------
# Local MVP free plan limits
# ------------------------------
FREE_MAX_AD_ACCOUNTS=1
FREE_MAX_FINDINGS=3
FREE_MAX_RECOMMENDATIONS=2
FREE_MAX_HISTORY_ITEMS=4
FREE_MAX_TREND_POINTS=6
FREE_MAX_REPORTS_PER_MONTH=3
