# ==============================================================
# Production environment — copy to .env and fill in all values
# NEVER commit this file with real secrets
# ==============================================================

# ------------------------------
# Core
# ------------------------------
ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql://user:password@your-db-host:5432/meta_ads_audit
REDIS_URL=redis://:your-redis-password@your-redis-host:6379/0

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<replace-with-generated-key>

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<replace-with-generated-key>

# ------------------------------
# CORS / URLs
# ------------------------------
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["https://yourdomain.com"]
FRONTEND_APP_URL=https://yourdomain.com

# ------------------------------
# Meta OAuth / API
# ------------------------------
META_APP_ID=<your-meta-app-id>
META_APP_SECRET=<your-meta-app-secret>
META_REDIRECT_URI=https://yourdomain.com/dashboard/meta/callback
META_API_VERSION=v19.0
META_OAUTH_SCOPES=ads_read,ads_management,business_management
META_STATE_TTL_MINUTES=10
META_INITIAL_SYNC_LOOKBACK_DAYS=90
META_INCREMENTAL_SYNC_LOOKBACK_DAYS=30
META_HTTP_TIMEOUT_SECONDS=60
META_PAGINATION_MAX_PAGES=250

# ------------------------------
# AI explanation layer
# Set AI_PROVIDER to: openai | anthropic | gemini | mock
# ------------------------------
AI_PROVIDER=gemini
AI_API_KEY=<your-ai-api-key>
AI_MODEL=gemini-1.5-flash
AI_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2
AI_PROMPT_VERSION=v1

# ------------------------------
# Email delivery (production SMTP)
# ------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=<your-sendgrid-or-smtp-password>
SMTP_FROM=noreply@yourdomain.com
SMTP_STARTTLS=true

# ------------------------------
# Sentry observability
# Create a project at https://sentry.io and paste the DSN below
# ------------------------------
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ------------------------------
# Rate limiting
# ------------------------------
RATE_LIMIT_AUTH_REQUESTS=6
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_UPLOAD_REQUESTS=6
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=3600
RATE_LIMIT_AUDIT_REQUESTS=10
RATE_LIMIT_AUDIT_WINDOW_SECONDS=3600

# ------------------------------
# Free plan limits
# ------------------------------
FREE_MAX_AD_ACCOUNTS=1
FREE_MAX_FINDINGS=3
FREE_MAX_RECOMMENDATIONS=2
FREE_MAX_HISTORY_ITEMS=4
FREE_MAX_TREND_POINTS=6
FREE_MAX_REPORTS_PER_MONTH=3
